#include <stdio.h>

#define MAX 1001

int parent[MAX];

// Find function (with path compression)
int find(int x) {
    if (parent[x] != x)
        parent[x] = find(parent[x]);
    return parent[x];
}

// Union function
int unionSet(int a, int b) {
    int pa = find(a);
    int pb = find(b);

    if (pa == pb)
        return 0; // cycle detected

    parent[pa] = pb;
    return 1;
}

int main() {
    int n;
    scanf("%d", &n);  // number of edges

    int edges[n][2];

    // input edges
    for (int i = 0; i < n; i++) {
        scanf("%d %d", &edges[i][0], &edges[i][1]);
    }

    // initialize parent
    for (int i = 1; i <= n; i++) {
        parent[i] = i;
    }

    int resA = -1, resB = -1;

    // process edges
    for (int i = 0; i < n; i++) {
        if (!unionSet(edges[i][0], edges[i][1])) {
            // cycle edge found
            resA = edges[i][0];
            resB = edges[i][1];
        }
    }

    printf("[%d,%d]\n", resA, resB);

    return 0;
}
