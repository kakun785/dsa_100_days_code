#include <stdio.h>

int removeElement(int arr[], int n, int val) {
    int k = 0;  // index for valid elements

    for (int i = 0; i < n; i++) {
        if (arr[i] != val) {
            arr[k] = arr[i];
            k++;
        }
    }

    return k;  // new length
}

int main() {
    int arr[] = {3, 2, 2, 3};
    int n = 4;
    int val = 3;

    int newLength = removeElement(arr, n, val);

    printf("New length: %d\n", newLength);
    printf("Updated array: ");

    for (int i = 0; i < newLength; i++) {
        printf("%d ", arr[i]);
    }

    return 0;
}
