#include <stdio.h>

int contains(int arr[], int size, int val) {
    for (int i = 0; i < size; i++) {
        if (arr[i] == val)
            return 1;
    }
    return 0;
}

int intersection(int nums1[], int n1, int nums2[], int n2, int result[]) {
    int k = 0;

    for (int i = 0; i < n1; i++) {
        if (contains(nums2, n2, nums1[i]) && !contains(result, k, nums1[i])) {
            result[k++] = nums1[i];
        }
    }

    return k;
}

int main() {
    int nums1[] = {1, 2, 2, 1};
    int nums2[] = {2, 2};
    int result[100];

    int size = intersection(nums1, 4, nums2, 2, result);

    printf("Intersection: ");
    for (int i = 0; i < size; i++) {
        printf("%d ", result[i]);
    }

    return 0;
}
