#include <stdio.h>

void moveZeroes(int arr[], int n) {
    int k = 0;  // position for non-zero elements

    // Step 1: Move non-zero elements forward
    for (int i = 0; i < n; i++) {
        if (arr[i] != 0) {
            arr[k] = arr[i];
            k++;
        }
    }

    // Step 2: Fill remaining positions with 0
    while (k < n) {
        arr[k] = 0;
        k++;
    }
}

int main() {
    int arr[] = {0, 1, 0, 3, 12};
    int n = 5;

    moveZeroes(arr, n);

    printf("Updated array: ");
    for (int i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }

    return 0;
}
