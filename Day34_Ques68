#include <iostream>
#include <stack>
using namespace std;

int calculate(string s) {
    stack<int> st;
    int num = 0;
    char op = '+';

    for (int i = 0; i < s.length(); i++) {
        char c = s[i];

        // Build number
        if (isdigit(c)) {
            num = num * 10 + (c - '0');
        }

        // If operator or end
        if ((!isdigit(c) && c != ' ') || i == s.length() - 1) {
            if (op == '+') {
                st.push(num);
            }
            else if (op == '-') {
                st.push(-num);
            }
            else if (op == '*') {
                int top = st.top(); st.pop();
                st.push(top * num);
            }
            else if (op == '/') {
                int top = st.top(); st.pop();
                st.push(top / num); // truncates toward zero
            }

            op = c;
            num = 0;
        }
    }

    // Final sum
    int result = 0;
    while (!st.empty()) {
        result += st.top();
        st.pop();
    }

    return result;
}

int main() {
    string s;
    getline(cin, s);

    cout << calculate(s);

    return 0;
}
