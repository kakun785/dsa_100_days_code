#include <stdio.h>

#define MAX 100

// Queue for storing positions
struct Pair {
    int x, y;
};

struct Pair queue[MAX * MAX];

int front = 0, rear = 0;

// Directions: up, down, left, right
int dx[] = {-1, 1, 0, 0};
int dy[] = {0, 0, -1, 1};

// Enqueue
void enqueue(int x, int y) {
    queue[rear].x = x;
    queue[rear].y = y;
    rear++;
}

// Dequeue
struct Pair dequeue() {
    return queue[front++];
}

// Check empty
int isEmpty() {
    return front == rear;
}

int main() {
    int m, n;
    scanf("%d %d", &m, &n);

    int grid[MAX][MAX];

    // Input grid
    for (int i = 0; i < m; i++)
        for (int j = 0; j < n; j++)
            scanf("%d", &grid[i][j]);

    int fresh = 0;

    // Add all rotten oranges to queue
    for (int i = 0; i < m; i++) {
        for (int j = 0; j < n; j++) {
            if (grid[i][j] == 2)
                enqueue(i, j);
            else if (grid[i][j] == 1)
                fresh++;
        }
    }

    int minutes = 0;

    // BFS
    while (!isEmpty() && fresh > 0) {
        int size = rear - front; // current level size

        for (int i = 0; i < size; i++) {
            struct Pair p = dequeue();

            for (int d = 0; d < 4; d++) {
                int nx = p.x + dx[d];
                int ny = p.y + dy[d];

                if (nx >= 0 && nx < m && ny >= 0 && ny < n && grid[nx][ny] == 1) {
                    grid[nx][ny] = 2;
                    enqueue(nx, ny);
                    fresh--;
                }
            }
        }
        minutes++;
    }

    if (fresh > 0)
        printf("-1");
    else
        printf("%d", minutes);

    return 0;
}
