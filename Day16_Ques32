def rotate(nums, k):
    n = len(nums)
    k = k % n   # handle k > n

    # helper function to reverse
    def reverse(start, end):
        while start < end:
            nums[start], nums[end] = nums[end], nums[start]
            start += 1
            end -= 1

    # Step 1
    reverse(0, n-1)
    # Step 2
    reverse(0, k-1)
    # Step 3
    reverse(k, n-1)

    return nums


# Example
nums = [1,2,3,4,5,6,7]
k = 3
print(rotate(nums, k))
