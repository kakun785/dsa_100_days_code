
#include <stdio.h>

void reverseString(char s[], int n) {
    int i = 0, j = n - 1;
    char temp;

    while (i < j) {
        temp = s[i];
        s[i] = s[j];
        s[j] = temp;

        i++;
        j--;
    }
}

int main() {
    char s[] = {'h','e','l','l','o'};
    int n = 5;

    reverseString(s, n);

    printf("Reversed: ");
    for (int i = 0; i < n; i++) {
        printf("%c", s[i]);
    }

    return 0;
}
