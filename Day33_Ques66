#include <iostream>
#include <stack>
#include <vector>
using namespace std;

int evalRPN(vector<string>& tokens) {
    stack<int> st;

    for (string token : tokens) {
        // Check if operator
        if (token == "+" || token == "-" || token == "*" || token == "/") {
            int b = st.top(); st.pop();
            int a = st.top(); st.pop();

            int result;

            if (token == "+") result = a + b;
            else if (token == "-") result = a - b;
            else if (token == "*") result = a * b;
            else result = a / b; // division truncates toward zero

            st.push(result);
        } 
        else {
            // Operand → convert string to int
            st.push(stoi(token));
        }
    }

    return st.top();
}

int main() {
    vector<string> tokens = {"2", "1", "+", "3", "*"};
    
    cout << evalRPN(tokens);

    return 0;
}
