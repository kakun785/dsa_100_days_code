#include <stdio.h>
#include <string.h>

#define MAX 100

int pq[MAX];
int size = 0;

// Insert in sorted order
void insert(int x) {
    int i;

    if (size == MAX) return;

    // Shift elements to maintain sorted order
    for (i = size - 1; i >= 0 && pq[i] > x; i--) {
        pq[i + 1] = pq[i];
    }

    pq[i + 1] = x;
    size++;
}

// Delete (remove smallest)
int delete() {
    if (size == 0) return -1;

    int val = pq[0];

    // Shift left
    for (int i = 1; i < size; i++) {
        pq[i - 1] = pq[i];
    }

    size--;
    return val;
}

// Peek (smallest)
int peek() {
    if (size == 0) return -1;
    return pq[0];
}

int main() {
    int N;
    scanf("%d", &N);

    char op[10];
    int x;

    for (int i = 0; i < N; i++) {
        scanf("%s", op);

        if (strcmp(op, "insert") == 0) {
            scanf("%d", &x);
            insert(x);
        }
        else if (strcmp(op, "delete") == 0) {
            int val = delete();
            if (val != -1)
                printf("%d\n", val);
            else
                printf("-1\n");
        }
        else if (strcmp(op, "peek") == 0) {
            int val = peek();
            if (val != -1)
                printf("%d\n", val);
            else
                printf("-1\n");
        }
    }

    return 0;
}
