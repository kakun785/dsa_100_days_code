#include <stdio.h>
#include <limits.h>

#define MAX 105

int findCheapestPrice(int n, int flights[][3], int flightsSize, int src, int dst, int k) {
    int dist[MAX], temp[MAX];

    // Initialize distances
    for (int i = 0; i < n; i++)
        dist[i] = INT_MAX;

    dist[src] = 0;

    // Relax edges k+1 times
    for (int i = 0; i <= k; i++) {
        // Copy current distances
        for (int j = 0; j < n; j++)
            temp[j] = dist[j];

        for (int j = 0; j < flightsSize; j++) {
            int u = flights[j][0];
            int v = flights[j][1];
            int cost = flights[j][2];

            if (dist[u] != INT_MAX && dist[u] + cost < temp[v]) {
                temp[v] = dist[u] + cost;
            }
        }

        // Update dist
        for (int j = 0; j < n; j++)
            dist[j] = temp[j];
    }

    return dist[dst] == INT_MAX ? -1 : dist[dst];
}

// Driver
int main() {
    int n = 4;
    int flights[][3] = {
        {0,1,100},
        {1,2,100},
        {2,0,100},
        {1,3,600},
        {2,3,200}
    };

    int src = 0, dst = 3, k = 1;

    int ans = findCheapestPrice(n, flights, 5, src, dst, k);
    printf("Output: %d\n", ans);

    return 0;
}
