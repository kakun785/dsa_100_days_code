#include <stdio.h>

#define MAX 100

int graph[MAX][MAX];
int color[MAX]; // -1 = not colored, 0 and 1 are colors

int dfs(int node, int c, int n) {
    color[node] = c;

    for (int i = 0; i < n; i++) {
        if (graph[node][i]) {
            if (color[i] == -1) {
                if (!dfs(i, 1 - c, n))
                    return 0;
            }
            else if (color[i] == c) {
                return 0; // same color conflict
            }
        }
    }
    return 1;
}

int isBipartite(int n) {
    for (int i = 0; i < n; i++) {
        color[i] = -1;
    }

    for (int i = 0; i < n; i++) {
        if (color[i] == -1) {
            if (!dfs(i, 0, n))
                return 0;
        }
    }
    return 1;
}

int main() {
    int n;
    scanf("%d", &n);

    // Input adjacency matrix
    for (int i = 0; i < n; i++) {
        int m;
        scanf("%d", &m); // number of neighbors

        for (int j = 0; j < m; j++) {
            int v;
            scanf("%d", &v);
            graph[i][v] = 1;
            graph[v][i] = 1;
        }
    }

    if (isBipartite(n))
        printf("true\n");
    else
        printf("false\n");

    return 0;
}
