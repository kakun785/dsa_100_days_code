#include <stdio.h>

int findMin(int nums[], int n) {
    int left = 0, right = n - 1;

    while (left < right) {
        int mid = (left + right) / 2;

        if (nums[mid] > nums[right]) {
            left = mid + 1;   // Min in right half
        } else {
            right = mid;      // Min in left half including mid
        }
    }

    return nums[left];
}

int main() {
    int n;
    scanf("%d", &n);

    int nums[5000];
    for (int i = 0; i < n; i++) {
        scanf("%d", &nums[i]);
    }

    int result = findMin(nums, n);
    printf("%d\n", result);

    return 0;
}
