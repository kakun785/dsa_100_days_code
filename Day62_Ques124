#include <stdio.h>

#define MAX 100

int visited[MAX];

// DFS function
void dfs(int room, int n, int rooms[MAX][MAX], int size[]) {
    visited[room] = 1;

    // Traverse all keys in this room
    for (int i = 0; i < size[room]; i++) {
        int nextRoom = rooms[room][i];

        if (!visited[nextRoom]) {
            dfs(nextRoom, n, rooms, size);
        }
    }
}

int main() {
    int n;
    scanf("%d", &n);

    int rooms[MAX][MAX]; // stores keys
    int size[MAX];       // number of keys in each room

    // Input
    for (int i = 0; i < n; i++) {
        scanf("%d", &size[i]);  // number of keys in room i
        for (int j = 0; j < size[i]; j++) {
            scanf("%d", &rooms[i][j]);
        }
    }

    // Initialize visited
    for (int i = 0; i < n; i++)
        visited[i] = 0;

    // Start DFS from room 0
    dfs(0, n, rooms, size);

    // Check if all visited
    for (int i = 0; i < n; i++) {
        if (!visited[i]) {
            printf("false");
            return 0;
        }
    }

    printf("true");
    return 0;
}
