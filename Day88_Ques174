def can_place(stalls, n, k, dist):
    count = 1  # first cow placed at first stall
    last_pos = stalls[0]

    for i in range(1, n):
        if stalls[i] - last_pos >= dist:
            count += 1
            last_pos = stalls[i]
        
        if count >= k:
            return True

    return False


def aggressive_cows(stalls, n, k):
    stalls.sort()

    low = 0
    high = stalls[-1] - stalls[0]
    answer = 0

    while low <= high:
        mid = (low + high) // 2

        if can_place(stalls, n, k, mid):
            answer = mid
            low = mid + 1  # try bigger distance
        else:
            high = mid - 1

    return answer


# Example
n, k = 5, 3
stalls = [1, 2, 8, 4, 9]

print(aggressive_cows(stalls, n, k))  # Output: 3
