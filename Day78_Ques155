#include <stdio.h>

#define MAX 100
#define INF 1000000

int graph[MAX][MAX];
int visited[MAX];

int main() {
    int n, m;
    scanf("%d %d", &n, &m);

    // Initialize graph
    for (int i = 1; i <= n; i++) {
        for (int j = 1; j <= n; j++) {
            graph[i][j] = INF;
        }
        visited[i] = 0;
    }

    // Input edges
    for (int i = 0; i < m; i++) {
        int u, v, w;
        scanf("%d %d %d", &u, &v, &w);
        graph[u][v] = w;
        graph[v][u] = w;
    }

    int totalWeight = 0;
    visited[1] = 1; // start from node 1

    // MST will have n-1 edges
    for (int count = 0; count < n - 1; count++) {
        int min = INF, u = -1, v = -1;

        for (int i = 1; i <= n; i++) {
            if (visited[i]) {
                for (int j = 1; j <= n; j++) {
                    if (!visited[j] && graph[i][j] < min) {
                        min = graph[i][j];
                        u = i;
                        v = j;
                    }
                }
            }
        }

        if (u != -1 && v != -1) {
            visited[v] = 1;
            totalWeight += min;
        }
    }

    printf("%d\n", totalWeight);

    return 0;
}
