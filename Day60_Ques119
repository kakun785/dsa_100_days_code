#include <stdio.h>

// Function to check Min-Heap
int isMinHeap(int arr[], int n) {
    // Check all parent nodes
    for (int i = 0; i <= (n - 2) / 2; i++) {

        // Left child index = 2*i + 1
        if (arr[i] > arr[2*i + 1])
            return 0;

        // Right child index = 2*i + 2
        if (2*i + 2 < n && arr[i] > arr[2*i + 2])
            return 0;
    }
    return 1;
}

int main() {
    int n;
    scanf("%d", &n);

    int arr[n];

    for (int i = 0; i < n; i++)
        scanf("%d", &arr[i]);

    if (isMinHeap(arr, n))
        printf("YES");
    else
        printf("NO");

    return 0;
}
