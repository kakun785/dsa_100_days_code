#include <stdio.h>

#define MAX 1000

int main() {
    int n;
    scanf("%d", &n);

    int arr[MAX];
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    int prefixSum = 0, maxLen = 0;

    // Simple hashmap using array (range assumption)
    int map[20001];
    for (int i = 0; i < 20001; i++) {
        map[i] = -2;  // -2 means not visited
    }

    map[10000] = -1; // prefixSum = 0 at index -1

    for (int i = 0; i < n; i++) {
        prefixSum += arr[i];

        int key = prefixSum + 10000; // shift for negative

        if (map[key] != -2) {
            int len = i - map[key];
            if (len > maxLen)
                maxLen = len;
        } else {
            map[key] = i;
        }
    }

    printf("%d\n", maxLen);

    return 0;
}
