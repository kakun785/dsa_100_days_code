#include <stdio.h>
#include <stdlib.h>

typedef struct {
    int pos;
    int speed;
} Car;

// Sort by position descending
int compare(const void *a, const void *b) {
    return ((Car*)b)->pos - ((Car*)a)->pos;
}

int carFleet(int target, Car cars[], int n) {

    qsort(cars, n, sizeof(Car), compare);

    double maxTime = 0.0;
    int fleets = 0;

    for (int i = 0; i < n; i++) {

        double time = (double)(target - cars[i].pos) / cars[i].speed;

        // New fleet if this car is slower than current slowest fleet
        if (time > maxTime) {
            fleets++;
            maxTime = time;
        }
    }

    return fleets;
}

int main() {
    int n, target;
    scanf("%d %d", &n, &target);

    Car cars[n];

    for (int i = 0; i < n; i++) {
        scanf("%d %d", &cars[i].pos, &cars[i].speed);
    }

    printf("%d\n", carFleet(target, cars, n));

    return 0;
}
