#include <stdio.h>
#include <string.h>

#define MAX 26

int adj[MAX][MAX];
int indegree[MAX];
int present[MAX];

// Queue
int queue[MAX];
int front = 0, rear = 0;

void enqueue(int x) {
    queue[rear++] = x;
}

int dequeue() {
    return queue[front++];
}

int isEmpty() {
    return front == rear;
}

int main() {
    int n;
    scanf("%d", &n);

    char words[n][100];

    // Input words
    for (int i = 0; i < n; i++) {
        scanf("%s", words[i]);
    }

    // Initialize
    for (int i = 0; i < MAX; i++) {
        indegree[i] = 0;
        present[i] = 0;
        for (int j = 0; j < MAX; j++) {
            adj[i][j] = 0;
        }
    }

    // Mark characters present
    for (int i = 0; i < n; i++) {
        for (int j = 0; words[i][j]; j++) {
            present[words[i][j] - 'a'] = 1;
        }
    }

    // Build graph
    for (int i = 0; i < n - 1; i++) {
        char *w1 = words[i];
        char *w2 = words[i + 1];

        int j = 0;
        while (w1[j] && w2[j] && w1[j] == w2[j]) {
            j++;
        }

        // Invalid case: prefix issue
        if (w1[j] && !w2[j]) {
            printf("");
            return 0;
        }

        if (w1[j] && w2[j]) {
            int u = w1[j] - 'a';
            int v = w2[j] - 'a';

            if (!adj[u][v]) {
                adj[u][v] = 1;
                indegree[v]++;
            }
        }
    }

    // Push indegree 0 nodes
    for (int i = 0; i < MAX; i++) {
        if (present[i] && indegree[i] == 0) {
            enqueue(i);
        }
    }

    char result[MAX];
    int idx = 0;

    // Topological Sort
    while (!isEmpty()) {
        int curr = dequeue();
        result[idx++] = curr + 'a';

        for (int i = 0; i < MAX; i++) {
            if (adj[curr][i]) {
                indegree[i]--;
                if (indegree[i] == 0) {
                    enqueue(i);
                }
            }
        }
    }

    // Count total unique chars
    int total = 0;
    for (int i = 0; i < MAX; i++) {
        if (present[i]) total++;
    }

    // If cycle
    if (idx != total) {
        printf("");
    } else {
        result[idx] = '\0';
        printf("%s", result);
    }

    return 0;
}
