#include <stdio.h>

#define MAX 100005

int graph[MAX][100];  // adjacency list (simplified)
int size[MAX];

int visited[MAX], disc[MAX], low[MAX], parent[MAX];
int ap[MAX]; // articulation point marker
int time = 0;

void dfs(int u) {
    visited[u] = 1;
    disc[u] = low[u] = ++time;

    int children = 0;

    for (int i = 0; i < size[u]; i++) {
        int v = graph[u][i];

        if (!visited[v]) {
            children++;
            parent[v] = u;

            dfs(v);

            // update low
            if (low[v] < low[u])
                low[u] = low[v];

            // Case 1: root
            if (parent[u] == -1 && children > 1)
                ap[u] = 1;

            // Case 2: non-root
            if (parent[u] != -1 && low[v] >= disc[u])
                ap[u] = 1;
        }
        else if (v != parent[u]) {
            // back edge
            if (disc[v] < low[u])
                low[u] = disc[v];
        }
    }
}

int main() {
    int V, E;
    scanf("%d %d", &V, &E);

    // init
    for (int i = 0; i < V; i++) {
        size[i] = 0;
        visited[i] = 0;
        parent[i] = -1;
        ap[i] = 0;
    }

    // input edges
    for (int i = 0; i < E; i++) {
        int u, v;
        scanf("%d %d", &u, &v);

        graph[u][size[u]++] = v;
        graph[v][size[v]++] = u;
    }

    // run DFS
    for (int i = 0; i < V; i++) {
        if (!visited[i]) {
            dfs(i);
        }
    }

    // print result
    int found = 0;
    for (int i = 0; i < V; i++) {
        if (ap[i]) {
            printf("%d ", i);
            found = 1;
        }
    }

    if (!found) printf("-1");

    return 0;
}
