#include <stdio.h>

#define MAX 100

// Directions: up, down, left, right
int dx[] = {-1, 1, 0, 0};
int dy[] = {0, 0, -1, 1};

// DFS function
void floodFill(int image[MAX][MAX], int m, int n, int x, int y, int oldColor, int newColor) {

    // Boundary + condition check
    if (x < 0 || x >= m || y < 0 || y >= n)
        return;

    if (image[x][y] != oldColor)
        return;

    // Change color
    image[x][y] = newColor;

    // Visit all 4 directions
    for (int i = 0; i < 4; i++) {
        floodFill(image, m, n, x + dx[i], y + dy[i], oldColor, newColor);
    }
}

int main() {
    int m, n;
    scanf("%d %d", &m, &n);

    int image[MAX][MAX];

    // Input image
    for (int i = 0; i < m; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &image[i][j]);
        }
    }

    int sr, sc, color;
    scanf("%d %d %d", &sr, &sc, &color);

    int oldColor = image[sr][sc];

    // Avoid infinite loop if same color
    if (oldColor != color) {
        floodFill(image, m, n, sr, sc, oldColor, color);
    }

    // Print result
    for (int i = 0; i < m; i++) {
        for (int j = 0; j < n; j++) {
            printf("%d ", image[i][j]);
        }
        printf("\n");
    }

    return 0;
}
