#include <stdio.h>
#include <stdlib.h>

// Node structure
struct Node {
    int data;
    struct Node* next;
};

// Create node
struct Node* newNode(int data) {
    struct Node* temp = (struct Node*)malloc(sizeof(struct Node));
    temp->data = data;
    temp->next = NULL;
    return temp;
}

// Add two numbers
struct Node* addTwoNumbers(struct Node* l1, struct Node* l2) {
    struct Node *result = NULL, *tail = NULL;
    int carry = 0;

    while (l1 != NULL || l2 != NULL || carry) {
        int sum = carry;

        if (l1 != NULL) {
            sum += l1->data;
            l1 = l1->next;
        }

        if (l2 != NULL) {
            sum += l2->data;
            l2 = l2->next;
        }

        struct Node* newNodePtr = newNode(sum % 10);
        carry = sum / 10;

        if (result == NULL) {
            result = tail = newNodePtr;
        } else {
            tail->next = newNodePtr;
            tail = newNodePtr;
        }
    }

    return result;
}

// Display list
void display(struct Node* head) {
    while (head != NULL) {
        printf("%d ", head->data);
        head = head->next;
    }
}

int main() {
    // Example: 2→4→3 and 5→6→4
    struct Node* l1 = newNode(2);
    l1->next = newNode(4);
    l1->next->next = newNode(3);

    struct Node* l2 = newNode(5);
    l2->next = newNode(6);
    l2->next->next = newNode(4);

    struct Node* result = addTwoNumbers(l1, l2);

    display(result);

    return 0;
}
