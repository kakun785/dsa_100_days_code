#include <stdio.h>

#define MAX 100
#define INF 1000000

int graph[MAX][MAX];
int dist[MAX];
int visited[MAX];

int main() {
    int n, m;
    scanf("%d %d", &n, &m);

    // Initialize
    for (int i = 1; i <= n; i++) {
        dist[i] = INF;
        visited[i] = 0;
        for (int j = 1; j <= n; j++) {
            graph[i][j] = INF;
        }
    }

    // Input edges
    for (int i = 0; i < m; i++) {
        int u, v, w;
        scanf("%d %d %d", &u, &v, &w);
        graph[u][v] = w;
        graph[v][u] = w; // remove if directed
    }

    int source = 1; // you can change source
    dist[source] = 0;

    // Dijkstra
    for (int count = 0; count < n - 1; count++) {
        int min = INF, u = -1;

        // Find minimum distance node
        for (int i = 1; i <= n; i++) {
            if (!visited[i] && dist[i] < min) {
                min = dist[i];
                u = i;
            }
        }

        visited[u] = 1;

        // Relax neighbors
        for (int v = 1; v <= n; v++) {
            if (!visited[v] && graph[u][v] != INF &&
                dist[u] + graph[u][v] < dist[v]) {
                dist[v] = dist[u] + graph[u][v];
            }
        }
    }

    // Output distances
    for (int i = 1; i <= n; i++) {
        printf("Distance from %d to %d = %d\n", source, i, dist[i]);
    }

    return 0;
}
